# 此 .gitignore 文件应放在 Unity 项目的根目录下
# 获取最新版本: https://github.com/github/gitignore/blob/main/Unity.gitignore

# Unity 自动生成的文件夹和缓存
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# 内存捕获文件（可能非常大且包含敏感数据）
/[Mm]emoryCaptures/

# 确保我们忽略 .meta 文件，但仅当与之对应的资源文件也被忽略时
!/[Aa]ssets/**/*.meta

# 如果你希望忽略 Asset Store Tools 插件，请取消注释下行
# /[Aa]ssets/AssetStoreTools*

# 自动生成的 Jetbrains Rider 插件
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio 或 VSCode 缓存目录
.vs/
.vscode/

# Gradle 缓存目录
.gradle/

# 自动生成的 Visual Studio、MonoDevelop 等解决方案和项目文件
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D 生成的特定 meta 文件
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D 在崩溃报告时生成的文件
sysinfo.txt

# 构建产物
*.apk
*.aab
*.unitypackage

# Crashlytics 生成的文件
crashlytics-build.properties

# 打包的 Addressables 文件
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# 临时自动生成的 Android 资源
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# macOS 生成的系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db